# Anthropic Claude API key — server-only, never exposed to the client.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Solana RPC endpoint. Default: devnet. For mainnet, use a Helius or QuickNode URL.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Network label shown in the UI. "devnet" | "mainnet-beta"
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Turso (libSQL) — production persistence on Vercel.
# Leave BLANK for local dev: the app falls back to file:./db/schedules.db.
# In production, create a DB with `turso db create solace` and a token with
# `turso db tokens create solace`, then set both values in the Vercel dashboard.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
